# 服务端口
PORT=3001

# 允许的前端域名（逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173

# 运行环境：development | production
NODE_ENV=development

# Token 过期时间（小时，默认 4）
TOKEN_TTL_HOURS=4

# LLM 配置（可选，仅 AI 对局需要）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-pro

# LLM 超时（毫秒）
LLM_TIMEOUT_MS=15000
